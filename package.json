{
  "name": "vite-project",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "npx wrangler pages dev dist --ip 127.0.0.1 --port 8788",
    "build": "vue-tsc && vite build",
    "test:contracts": "node --experimental-strip-types scripts/test-api-contracts.mjs",
    "smoke:local": "./scripts/smoke-local.sh",
    "ci:local": "npm run build && npm run test:contracts && npm run smoke:local",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=promptexecution-comic --env production",
    "db:init": "npx wrangler d1 execute llm-comic-db --file=./schema.sql",
    "db:init:local": "npx wrangler d1 execute llm-comic-db --local --file=./schema.sql",
    "db:query": "npx wrangler d1 execute llm-comic-db --command",
    "logs": "npx wrangler pages deployment tail --project-name=promptexecution-comic"
  },
  "dependencies": {
    "@achrinza/node-ipc": "10.1.11",
    "@types/three": "^0.179.0",
    "mitt": "^3.0.1",
    "path": "^0.12.7",
    "pinia": "3.0.3",
    "three": "^0.179.1",
    "v-idle-3": "^0.3.14",
    "vue": "3.5.18",
    "vue-cookie-next": "^1.3.0",
    "vue-gtag-next": "^1.14.0",
    "vue-native-websocket-vue3": "3.1.8",
    "vue-web-terminal": "3.4.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.1",
    "typescript": "5.9.2",
    "vite": "7.1.1",
    "vue-tsc": "3.0.5",
    "wrangler": "^4.0.0"
  },
  "packageManager": "npm@10.9.2"
}
